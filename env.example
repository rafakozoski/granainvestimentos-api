# ============================================================
#  GRANA INVESTIMENTOS — variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# BRAPI — cotações e fundamentalistas (gratuito: 15 req/min)
# Cadastro em: https://brapi.dev
BRAPI_TOKEN=seu_token_aqui

# Porta do servidor (Railway define automaticamente)
PORT=3000

# URL do front-end (para CORS) — troque pelo seu domínio
FRONTEND_URL=https://granainvestimentos.com.br

# Ambiente
NODE_ENV=production
